rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (optional)
    //   - email: string (required)
    //   - photoURL: string (optional)
    //   - friends: list of strings (required)
    //
    // Collection: results
    // Document ID: {resultId}
    // Fields:
    //   - uid: string (required)
    //   - profile: map (required)
    //   - timestamp: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'friends']) &&
             data.uid is string &&
             data.email is string &&
             data.friends is list;
    }

    function isValidResult(data) {
      return data.keys().hasAll(['uid', 'profile', 'timestamp']) &&
             data.uid is string &&
             data.profile is map &&
             data.timestamp is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      // Users can read any profile to find friends or see friend names
      // But we should be careful with PII. 
      // For this app, let's allow reading displayName and photoURL.
      // Actually, for simplicity in this demo, we'll allow reading the whole doc if authenticated.
      allow read: if isAuthenticated();
      
      // Only owner can create or update their own profile
      allow create: if isOwner(uid) && isValidUser(request.resource.data);
      allow update: if isOwner(uid) && isValidUser(request.resource.data);
    }

    match /results/{resultId} {
      // Anyone authenticated can read results to calculate averages
      allow read: if isAuthenticated();
      
      // Users can only create results for themselves
      allow create: if isAuthenticated() && 
                      request.resource.data.uid == request.auth.uid && 
                      isValidResult(request.resource.data);
      
      // Results are immutable
      allow update, delete: if false;
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
